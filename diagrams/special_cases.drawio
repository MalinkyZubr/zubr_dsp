        </mxCell>
        <mxCell id="DtVYKYvhivc_cz4grxBP-2" value="if I encapsulate node types in an enum I decouple data transfer behavior from the step definiton. This would be a positive change" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
