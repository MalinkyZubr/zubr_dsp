<mxfile host="Electron" agent="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/28.2.5 Chrome/138.0.7204.251 Electron/37.6.1 Safari/537.36" version="28.2.5">
  <diagram name="Page-1" id="nsKuF7r1AUfED6OHO5Vg">
    <mxGraphModel dx="1595" dy="848" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="xm97tIzFpSOHS7XiSRMR-2" value="Goal: I need a priority queue to place tasks into the thread pool in order. Since data flows from one node to the next, if one thread tries to run with unsatisfied dependencies too far back in the dependency graph, there is a high probability for it to lock. Hence a system needs to be put in place to minimize lockups, wihtout sacraficing the benefits of multithreading. Can this just be viewed as a breadth first traversal of a tree? Directed acyclic graph is more accurate. Loops are not a concern because from the point of view of the computation, it can be treated as a branch with an external data sink. How it handles series data is another question, however.&amp;nbsp;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="520" height="190" as="geometry" />
        </mxCell>
        <mxCell id="xm97tIzFpSOHS7XiSRMR-12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="xm97tIzFpSOHS7XiSRMR-3" target="xm97tIzFpSOHS7XiSRMR-4">
